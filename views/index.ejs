<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Classroom Dashboard</title>
    <!-- This line pulls in Tailwind CSS so we can style everything instantly -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen">

    <!-- Top Navigation Bar -->
    <nav class="bg-white shadow-sm border-b border-slate-200 p-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold text-indigo-600">Chemistry Class</h1>
            <div class="bg-slate-100 px-4 py-1.5 rounded-full text-sm font-medium">
                <span class="text-indigo-600 font-semibold"><%= username %></span>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="max-w-6xl mx-auto p-6 mt-6">
        
        <!-- Welcome Banner -->
        <header class="bg-gradient-to-r from-indigo-500 to-purple-600 rounded-2xl p-6 text-white shadow-md mb-8">
            <h2 class="text-2xl font-bold mb-2">Hello, <%= username %>!</h2>
            <p class="text-indigo-100">Welcome to your dashboard. Select an activity below to get started on today's lessons.</p>
        </header>

        <!-- Quick Actions / Cards Grid -->
        <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
            
            <!-- Card 1: Quizzes -->
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 hover:shadow-md transition duration-200">
                <div class="text-3xl mb-3">📝</div>
                <h3 class="text-lg font-bold text-slate-900 mb-1">Assignments & Quizzes</h3>
                <p class="text-slate-500 text-sm mb-4">View active tests, practice quizzes, and check your latest scores.</p>
                <a href="/quizzes" class="inline-block bg-indigo-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-indigo-700 transition">
                    Open Quizzes
                </a>
            </div>

            <!-- Card 2: Lessons -->
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 hover:shadow-md transition duration-200">
                <div class="text-3xl mb-3">🧪</div>
                <h3 class="text-lg font-bold text-slate-900 mb-1">Study Modules</h3>
                <p class="text-slate-500 text-sm mb-4">Review class study guides, atomic theories, and chemistry resources.</p>
                <button class="inline-block bg-slate-100 text-slate-600 text-sm font-semibold px-4 py-2 rounded-lg cursor-not-allowed" disabled>
                    Coming Soon
                </button>
            </div>

            <!-- Card 3: Performance -->
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 hover:shadow-md transition duration-200">
                <div class="text-3xl mb-3">📊</div>
                <h3 class="text-lg font-bold text-slate-900 mb-1">Gradebook</h3>
                <p class="text-slate-500 text-sm mb-4">Track your points, view progress trends, and see teacher feedback.</p>
                <button class="inline-block bg-slate-100 text-slate-600 text-sm font-semibold px-4 py-2 rounded-lg cursor-not-allowed" disabled>
                    Coming Soon
                </button>
            </div>

        </section>

    </main>

</body>
</html>
