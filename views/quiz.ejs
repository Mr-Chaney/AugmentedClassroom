<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= quizName %></title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-slate-50 text-slate-800 font-sans transition-all duration-300">

    <nav class="bg-white shadow-sm p-4 border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <button id="exit-btn" class="text-sm font-bold text-slate-500 hover:text-red-600 transition cursor-pointer">✕ Save & Exit Practice</button>
            <div class="flex items-center space-x-4">
                <button id="calc-toggle-btn" class="bg-indigo-100 text-indigo-700 hover:bg-indigo-200 font-bold px-4 py-1.5 rounded-lg text-sm transition cursor-pointer flex items-center space-x-1">
                    <span>🧮</span> <span>Toggle Desmos Calculator</span>
                </button>
                <span id="session-score" class="text-sm font-bold bg-emerald-100 text-emerald-800 px-3 py-1 rounded-full">+0 XP Earned This Run</span>
            </div>
        </div>
    </nav>

    <div id="workspace-layout" class="max-w-3xl mx-auto p-6 mt-4 transition-all duration-300">
        <div id="grid-container" class="grid grid-cols-1 gap-8 transition-all duration-300">
            
            <main id="quiz-column" class="w-full">
                <div id="quiz-container">
                    </div>

                <div class="mt-6 flex space-x-3">
                    <button id="check-btn" class="w-full bg-indigo-600 text-white font-bold py-4 rounded-xl shadow-md hover:bg-indigo-700 transition cursor-pointer">Check Answer</button>
                    <button id="next-btn" class="hidden w-full bg-slate-800 text-white font-bold py-4 rounded-xl shadow-md hover:bg-slate-900 transition cursor-pointer">Next Question →</button>
                </div>
            </main>

            <aside id="calculator-column" class="hidden w-full bg-white border border-slate-200 rounded-2xl p-4 shadow-sm h-[550px] lg:sticky lg:top-24">
                <div id="desmos-frame-container" class="w-full h-full rounded-xl overflow-hidden">
                    </div>
            </aside>

        </div>
    </div>

    <script>
        const originalSourceQuestions = (<%- JSON.stringify(compiledQuestions) %>).flat();
        console.log("Frontend received questions:", originalSourceQuestions);
        const unitId = "<%= unitId %>";
        const quizIndex = "<%= quizIndex %>";

        // TELEMETRY TRACKING VARS
        const quizStartTime = new Date().toISOString(); // Logs exact moment quiz initialized
        let attemptedQuestionIds = [];

        let questionQueue = [...originalSourceQuestions];
        let pointsEarnedThisSession = 0;
        let activeIndex = 0;

        const container = document.getElementById('quiz-container');
        const checkBtn = document.getElementById('check-btn');
        const nextBtn = document.getElementById('next-btn');
        const sessionScoreTracker = document.getElementById('session-score');

        const calcToggleBtn = document.getElementById('calc-toggle-btn');
        const workspaceLayout = document.getElementById('workspace-layout');
        const gridContainer = document.getElementById('grid-container');
        const calculatorColumn = document.getElementById('calculator-column');
        const desmosContainer = document.getElementById('desmos-frame-container');
        
        let isCalculatorOpen = false;

        // FIXED: Universal iframe toggler that bypasses 403 validation bans entirely
        calcToggleBtn.addEventListener('click', () => {
            isCalculatorOpen = !isCalculatorOpen;
            
            if (isCalculatorOpen) {
                workspaceLayout.className = "max-w-6xl mx-auto p-6 mt-4 transition-all duration-300";
                gridContainer.className = "grid grid-cols-1 lg:grid-cols-2 gap-8";
                calculatorColumn.classList.remove('hidden');
                calcToggleBtn.className = "bg-indigo-600 text-white font-bold px-4 py-1.5 rounded-lg text-sm transition cursor-pointer flex items-center space-x-1";

                if (!desmosContainer.innerHTML.trim()) {
                    desmosContainer.innerHTML = `<iframe src="https://www.desmos.com/scientific" class="w-full h-full min-h-[500px] border-0"></iframe>`;
                }
            } else {
                workspaceLayout.className = "max-w-3xl mx-auto p-6 mt-4 transition-all duration-300";
                gridContainer.className = "grid grid-cols-1 gap-8";
                calculatorColumn.classList.add('hidden');
                calcToggleBtn.className = "bg-indigo-100 text-indigo-700 hover:bg-indigo-200 font-bold px-4 py-1.5 rounded-lg text-sm transition cursor-pointer flex items-center space-x-1";
            }
        });

        const motivators = ["Correct!", "Brilliant!", "Spot On!", "Excellent!", "Awesome!", "Nice Job!"];

        function reRollAlgorithmicQuestion(q) {
            if (q.type !== 'algorithmic-math' || !q.spreadsheetVariables) return q;
            let context = {};
            if (!q.rawTemplateText) {
                q.rawTemplateText = "Element [e] has three isotopes: [e]-[m1], [e]-[m2], and [e]-[m3], which have abundances of [a1]%, [a2]%, and [a3]% respectively. What is the average atomic mass of element [e]?";
            }
            let instanceText = q.rawTemplateText;
            const elements = ["X", "Y", "Z", "Q", "A", "G"];
            context['e'] = elements[Math.floor(Math.random() * elements.length)];

            let varSpecs = q.spreadsheetVariables.split(';');
            varSpecs.forEach(spec => {
                if (!spec.trim()) return;
                let [name, command] = spec.trim().split('=');
                name = name.trim(); command = command.trim();
                if (command.startsWith('int')) {
                    let [min, max] = command.replace('int(', '').replace(')', '').split(',').map(Number);
                    context[name] = Math.floor(Math.random() * (max - min + 1)) + min;
                
                } else if (command.startsWith('float')) {
                    let [min, max, dec] = command.replace('float(', '').replace(')', '').split(',').map(Number);
                    let rand = Math.random() * (max - min) + min;
                    context[name] = parseFloat(rand.toFixed(dec));
                }else if (command.startsWith('choice')) {
                let options = command.replace('choice(', '').replace(')', '')
                                     .split(',')
                                     .map(str => str.trim().replace(/['"]/g, '')); // Strips out quote marks
                context[name] = options[Math.floor(Math.random() * options.length)];
            }
            });

            if (q.spreadsheetEquations) {
                let eqSpecs = q.spreadsheetEquations.split(';');
                eqSpecs.forEach(spec => {
                    if (!spec.trim()) return;
                    let [name, expression] = spec.trim().split('=');
                    name = name.trim(); expression = expression.trim();
                    let fn = new Function(...Object.keys(context), `return ${expression};`);
                    let result = fn(...Object.values(context));
                    context[name] = typeof result === 'number' && !Number.isInteger(result) ? parseFloat(result.toFixed(2)) : result;
                });
            }

            for (let key in context) {
                instanceText = instanceText.replace(new RegExp(`\\[${key}\\]`, 'g'), `<strong>${context[key]}</strong>`);
            }

            let formulaFn = new Function(...Object.keys(context), `return ${q.spreadsheetFormula};`);
            let rawAnswer = formulaFn(...Object.values(context));
            let finalizedAnswer = q.roundingMode === 'sigfigs' 
                ? parseFloat(rawAnswer.toPrecision(q.roundingValue))
                : parseFloat(rawAnswer.toFixed(q.roundingValue));

            return { ...q, questionText: instanceText, computedAnswer: finalizedAnswer };
        }

        function renderActiveQuestion() {
            const container = document.getElementById('question-workspace');
            container.innerHTML = ''; // Clear workspace

            let q = questionQueue[activeIndex];
            if (!q) return;

            // Track unique question IDs for teacher audit logging telemetry
            if (q.id && !attemptedQuestionIds.includes(q.id)) {
                attemptedQuestionIds.push(q.id);
            }

            // -----------------------------------------------------------------
            // TYPE 1 & 2: MULTIPLE CHOICE & MULTI-SELECT
            // -----------------------------------------------------------------
             if (q.type === 'multiple-choice' || q.type === 'mc' || q.type === 'multi-select') {
                let html = `
                    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm mb-6 animate-fadeIn">
                        <span class="inline-block px-3 py-1 bg-indigo-50 text-indigo-600 rounded-full text-xs font-bold mb-3 uppercase tracking-wider">
                            ${q.type === 'multi-select' ? 'Select All That Apply' : 'Multiple Choice'} (${q.pointValue} XP)
                        </span>
                        <h3 class="text-xl font-bold text-slate-800 leading-snug">${q.questionText}</h3>
                    </div>
                    <div class="grid gap-3">
                `;

                q.options.forEach((opt, oIdx) => {
                    const inputType = q.type === 'multi-select' ? 'checkbox' : 'radio';
                    html += `
                        <label class="flex items-center p-4 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 cursor-pointer shadow-xs transition group relative active:scale-[0.99]">
                            <input type="${inputType}" name="quiz-option" value="${oIdx}" class="w-5 h-5 text-indigo-600 focus:ring-indigo-500 border-slate-300 rounded">
                            <span class="ml-4 font-medium text-slate-700 group-hover:text-slate-900">${opt}</span>
                        </label>
                    `;
                });

                html += `</div>`;
                container.innerHTML = html;
            } 
            // -----------------------------------------------------------------
            // TYPE 3: DROPDOWN (BLANK SEGMENTS MATCHING LINE)
            // -----------------------------------------------------------------
            else if (q.type === 'dropdown') {
                let html = `
                    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm mb-6 animate-fadeIn">
                        <span class="inline-block px-3 py-1 bg-amber-50 text-amber-600 rounded-full text-xs font-bold mb-3 uppercase tracking-wider">
                            Fill in the Blanks (${q.pointValue} XP)
                        </span>
                        <div class="text-lg font-medium text-slate-800 leading-relaxed">
                `;

                // Reconstruct sentence by threading text segments and select elements together
                q.textSegments.forEach((segment, sIdx) => {
                    html += segment;
                    if (q.blanks && q.blanks[sIdx]) {
                        html += `
                            <select name="quiz-dropdown" data-blank-index="${sIdx}" class="mx-1 my-1 inline-block bg-slate-50 border border-slate-300 text-slate-900 font-bold text-sm rounded-lg focus:ring-indigo-500 focus:border-indigo-500 p-1.5 shadow-xs">
                                <option value="" disabled selected>Choose...</option>
                                ${q.blanks[sIdx].options.map(opt => `<option value="${opt}">${opt}</option>`).join('')}
                            </select>
                        `;
                    }
                });

                html += `
                        </div>
                    </div>
                `;
                container.innerHTML = html;
            }
            // -----------------------------------------------------------------
            // TYPE 4: ALGORITHMIC MATH FILL-IN-THE-BLANK (DESMOS MATCHED CANVAS)
            // -----------------------------------------------------------------
            else if (q.type === 'algorithmic-math') {
                let html = `
                    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm mb-6 animate-fadeIn">
                        <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-600 rounded-full text-xs font-bold mb-3 uppercase tracking-wider">
                            Algorithmic Math (${q.pointValue} XP)
                        </span>
                        <h3 class="text-xl font-bold text-slate-800 leading-snug mb-4">${q.questionText}</h3>
                        
                        <div class="flex items-center space-x-3 mt-4">
                            <input type="number" id="math-numerical-input" step="any" placeholder="Enter calculated value" class="bg-slate-50 border border-slate-300 text-slate-900 font-bold text-base rounded-xl focus:ring-indigo-500 focus:border-indigo-500 block w-64 p-3 shadow-inner">
                            <span class="text-lg font-bold text-slate-600">${q.unitSymbol || ''}</span>
                        </div>
                    </div>
                    
                    <div class="bg-slate-900 p-4 rounded-2xl border border-slate-800 shadow-xl mt-6">
                        <div class="flex items-center justify-between mb-3 px-2">
                            <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Desmos Dynamic Scratchpad Workbench Engine</span>
                            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                        </div>
                        <div id="desmos-calculator-workspace" class="w-full h-80 rounded-xl overflow-hidden shadow-md"></div>
                    </div>
                `;

                container.innerHTML = html;

                // Fire up Desmos API instantiation bounds safely post render cycle loop
                setTimeout(() => {
                    const calcEl = document.getElementById('desmos-calculator-workspace');
                    if (calcEl && typeof Desmos !== 'undefined') {
                        Desmos.GraphingCalculator(calcEl, {
                            keypad: true,
                            expressions: true,
                            settingsMenu: false,
                            zoomButtons: true
                        });
                    }
                }, 50);
            }
        }

        checkBtn.addEventListener('click', () => {
            let q = questionQueue[activeIndex];
            let card = document.getElementById('card-wrapper');
            let bar = document.getElementById('feedback-bar');
            let isCorrect = false;

            if (q.type === 'multiple-choice') {
                let selected = document.querySelector('input[name="active_choices"]:checked');
                if (!selected) return alert("Please pick an option first!");
                isCorrect = parseInt(selected.value) === q.correctIndex;
            } 
            else if (q.type === 'multi-select') {
                let checkedBoxes = Array.from(document.querySelectorAll('input[name="active_choices"]:checked')).map(cb => parseInt(cb.value));
                isCorrect = q.correctIndices.length === checkedBoxes.length && q.correctIndices.every(val => checkedBoxes.includes(val));
            } 
            else if (q.type === 'dropdown') {
                let allBlanksCorrect = true;
                q.blanks.forEach((blank, bIdx) => {
                    let selectEl = document.querySelector(`select[name="blank_${bIdx}"]`);
                    if (!selectEl || selectEl.value !== blank.correct) allBlanksCorrect = false;
                });
                isCorrect = allBlanksCorrect;
            }
            else if (q.type === 'algorithmic-math') {
                let inputField = document.getElementById('math-input');
                if (!inputField.value) return alert("Please submit a value!");
                isCorrect = parseFloat(inputField.value) === q.computedAnswer;
            }

            checkBtn.classList.add('hidden');
            nextBtn.classList.remove('hidden');
            bar.classList.remove('hidden');

            if (isCorrect) {
                card.className = "bg-emerald-50 border-2 border-emerald-400 p-6 rounded-2xl shadow-sm transition-all duration-300";
                bar.className = "p-3 rounded-xl text-center font-bold text-sm mb-4 bg-emerald-500 text-white";
                bar.textContent = motivators[Math.floor(Math.random() * motivators.length)];
                
                if (!q.isReview) {
                    pointsEarnedThisSession += q.pointValue;
                    sessionScoreTracker.textContent = `+${pointsEarnedThisSession} XP Earned This Run`;
                }

                if (q.type === 'algorithmic-math') {
                    let originalTemplate = originalSourceQuestions.find(orig => orig.originalIndex === q.originalIndex);
                    if (originalTemplate) {
                        questionQueue[activeIndex] = reRollAlgorithmicQuestion({ ...originalTemplate });
                    }
                }
            } else {
                card.className = "bg-red-50 border-2 border-red-400 p-6 rounded-2xl shadow-sm transition-all duration-300";
                bar.className = "p-3 rounded-xl text-center font-bold text-sm mb-4 bg-red-500 text-white";
                bar.textContent = "Incorrect. This question has been re-queued into your review loop.";

                let reQueue = { ...q, isReview: true };
                questionQueue.push(reQueue);
            }

            document.querySelectorAll('input, select').forEach(el => el.disabled = true);
        });

        nextBtn.addEventListener('click', () => {
            activeIndex++;
            renderActiveQuestion();
        });

        function saveAndExit() {
            fetch(`/quiz/${unitId}/${quizIndex}/save-points`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ pointsEarnedThisSession: pointsEarnedThisSession })
            })
            .then(res => res.json())
            .then(data => { if(data.redirectUrl) window.location.href = data.redirectUrl; });
        }

        document.getElementById('exit-btn').addEventListener('click', saveAndExit);
        renderActiveQuestion();

        // Update your saveAndExit function to pass the telemetry payload data package
        function saveAndExit() {
            fetch(`/quiz/${unitId}/${quizIndex}/save-points`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ 
                    pointsEarnedThisSession: pointsEarnedThisSession,
                    startTime: quizStartTime,
                    endTime: new Date().toISOString(), // Captured right at submission save click
                    attemptedQuestionIds: attemptedQuestionIds
                })
            })
            .then(res => res.json())
            .then(data => { if(data.redirectUrl) window.location.href = data.redirectUrl; });
        }
    </script>

</body>
</html>